# Backend Environment Variables Example
# Copy this to .env and update values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/fitness-wellness-portal

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/fitness-wellness-portal

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_keep_it_long_and_complex
JWT_EXPIRE=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Optional: For production
# NODE_ENV=production
